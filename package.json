{
  "name": "avalon-online",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- tsx watch server.ts",
    "dev:neon": "dotenv -e .env.neon -- tsx watch server.ts",
    "build": "next build",
    "start": "NODE_ENV=production tsx server.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:logs": "docker compose logs -f postgres",
    "prisma:generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:neon": "dotenv -e .env.neon -- prisma migrate dev",
    "dbcheck": "dotenv -e .env -- tsx scripts/dbcheck.ts",
    "dbcheck:neon": "dotenv -e .env.neon -- tsx scripts/dbcheck.ts",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@tanstack/react-query": "^5.64.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.16.4",
    "nanoid": "^5.0.9",
    "next": "15.1.4",
    "next-intl": "^3.26.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.1.4",
    "husky": "^9.1.7",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
