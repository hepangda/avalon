# Copy to .env for local development.
#
# Default local setup uses Docker Compose (see docker-compose.yml):
#   npm run db:up        # start local Postgres
#   npm run migrate      # apply migrations to it
#   npm run dev          # run the app against it
#
# No pooler locally, so DATABASE_URL and DIRECT_URL are identical.
DATABASE_URL="postgresql://avalon:avalon@localhost:5432/avalon?schema=public"
DIRECT_URL="postgresql://avalon:avalon@localhost:5432/avalon?schema=public"

# Server
PORT=3000
HOST=0.0.0.0
