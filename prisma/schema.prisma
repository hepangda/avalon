// Avalon Online — Prisma schema.
//
// Authoritative game state lives in server memory; this database persists
// key checkpoints (event log + per-round results + final reveal) so games
// survive process restarts and can be replayed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoomStatus {
  lobby
  in_game
  finished
}

enum VoteValueDb {
  approve
  reject
}

enum MissionCardDb {
  success
  fail
}

enum TeamDb {
  good
  evil
}

model Room {
  id           String     @id @default(cuid())
  code         String     @unique
  hostPlayerId String
  status       RoomStatus @default(lobby)
  // Serialized GameConfig + room options (max players, allow spectators,
  // allow mid-join, enabled roles, lady of the lake).
  config       Json
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  players Player[]
  games   Game[]

  @@index([status])
}

model Player {
  id          String   @id @default(cuid())
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name        String
  seat        Int
  isSpectator Boolean  @default(false)
  // A seat is part of the host-defined roster. `claimed` = a live participant
  // has taken this seat (independent of `connected`, which tracks the socket).
  // claimed=false → empty seat anyone may claim.
  claimed     Boolean  @default(false)
  connected   Boolean  @default(true)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([roomId, seat])
  @@index([roomId])
}

model Game {
  id         String    @id @default(cuid())
  roomId     String
  room       Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  seed       String
  // Full role assignment — written at game start, only surfaced to clients at
  // GameOver. Kept server-side authoritative for replay reconstruction.
  roleAssignments Json
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  // Serialized GameOutcome once the game ends.
  outcome    Json?

  events        GameEvent[]
  rounds        Round[]
  ladyChecks    LadyInspection[]
  assassination Assassination?

  @@index([roomId])
}

// Append-only event log — the source of truth for replay & rebuild.
model GameEvent {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  seq       Int
  type      String
  payload   Json
  createdAt DateTime @default(now())

  @@unique([gameId, seq])
  @@index([gameId])
}

model Round {
  id                  String    @id @default(cuid())
  gameId              String
  game                Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  roundIndex          Int
  leaderPlayerId      String
  teamSize            Int
  finalTeam           Json? // PlayerId[] of the approved team (null if never approved)
  approved            Boolean?
  missionSuccess      Boolean?
  failCount           Int?
  rejectionsThisRound Int       @default(0)
  createdAt           DateTime  @default(now())

  votes        Vote[]
  missionCards MissionCardRow[]

  @@unique([gameId, roundIndex])
  @@index([gameId])
}

model Vote {
  id            String      @id @default(cuid())
  roundId       String
  round         Round       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  proposalIndex Int // which proposal within the round (0-based, rises on reject)
  playerId      String
  value         VoteValueDb
  createdAt     DateTime    @default(now())

  @@index([roundId])
}

// Per-player mission cards. SENSITIVE: who played what is never sent to clients
// during play; surfaced only in post-game replay.
model MissionCardRow {
  id        String        @id @default(cuid())
  roundId   String
  round     Round         @relation(fields: [roundId], references: [id], onDelete: Cascade)
  playerId  String
  card      MissionCardDb
  createdAt DateTime      @default(now())

  @@unique([roundId, playerId])
  @@index([roundId])
}

model LadyInspection {
  id             String   @id @default(cuid())
  gameId         String
  game           Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  roundIndex     Int
  holderPlayerId String
  targetPlayerId String
  revealedTeam   TeamDb
  createdAt      DateTime @default(now())

  @@index([gameId])
}

model Assassination {
  id              String   @id @default(cuid())
  gameId          String   @unique
  game            Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  assassinPlayerId String
  targetPlayerId  String
  hitMerlin       Boolean
  createdAt       DateTime @default(now())
}
